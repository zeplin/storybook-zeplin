{
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "target": "ES2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "declaration": true,
        "strict": true,
        "jsx": "react",
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "verbatimModuleSyntax": false
    },
    "include": ["src/**/*"]
}
