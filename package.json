{
    "name": "storybook-zeplin",
    "version": "4.0.0",
    "description": "Zeplin addon for Storybook",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./manager": "./dist/manager.js",
        "./preset": "./dist/preset.js",
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "preset.js"
    ],
    "keywords": [
        "storybook",
        "zeplin",
        "addon",
        "storybook-addon",
        "design"
    ],
    "scripts": {
        "prepare": "npm run build",
        "build": "tsc",
        "watch": "tsc --watch --preserveWatchOutput",
        "storybook": "NODE_ENV=development storybook dev -p 9001 -c .storybook",
        "build-storybook": "NODE_ENV=production storybook build",
        "format": "prettier --write ."
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/zeplin/storybook-zeplin.git"
    },
    "author": {
        "name": "Mert Kahyaoğlu",
        "url": "https://github.com/mertkahyaoglu"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/zeplin/storybook-zeplin/issues"
    },
    "homepage": "https://github.com/zeplin/storybook-zeplin#readme",
    "dependencies": {
        "@storybook/icons": "^1.2.9",
        "@zeplin/sdk": "^1.9.0",
        "query-string": "^6.12.1"
    },
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18",
        "storybook": "^10.0.0"
    },
    "devDependencies": {
        "@storybook/addon-webpack5-compiler-swc": "^3.0.0",
        "@storybook/react-webpack5": "^10.0.0",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "prettier": "^3.8.3",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "storybook": "^10.0.0",
        "typescript": "^5.5.3"
    }
}
